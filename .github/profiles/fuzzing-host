[settings]
arch=x86_64
build_type=Release
compiler=gcc
compiler.cppstd=20
compiler.libcxx=libstdc++11
compiler.version=13
os=Linux

[conf]
tools.cmake.cmaketoolchain:extra_variables={'Aleph_BUILD_FUZZING': 'ON'}
tools.build:cflags=['-fsanitize=fuzzer,address']
tools.build:cxxflags=['-fsanitize=fuzzer,address']
tools.build:exelinkflags=['-fsanitize=fuzzer,address']
tools.build:sharedlinkflags=['-fsanitize=fuzzer,address']